######################################
########## NFS Server (On - Permises) #############
@@ Install:

[root@k8s-control01 ~]# dnf install nfs-utils -y

@@ Create Share:
[root@k8s-control01 ~]# mkdir -p /nfs-share/k8s
[root@k8s-control01 ~]# chmod 777 /nfs-share/k8s

@@ Configure:
[root@k8s-control01 ~]# vim /etc/exports
/nfs-share/k8s *(rw,sync,no_root_squash)

@@ Apply:
[root@k8s-control01 ~]# exportfs -rav

@@ Enable:
[root@k8s-control01 ~]# systemctl enable --now nfs-server

@@ Verify from worker node:
[root@k8s-control01 ~]# showmount -e 10.10.10.100

@@ Expected:
/nfs-share/k8s

@@ Static Provisioning with NFS

[root@k8s-control01 ~]#  vim pv.yml
apiVersion: v1
kind: PersistentVolume
metadata:
  name: nfs-pv
spec:
  capacity:
    storage: 20Gi
  accessModes:
  - ReadWriteMany
  nfs:
    path: /nfs-share/k8s
    server: 10.10.10.100

@@ Apply:
[root@k8s-control01 ~]# kubectl apply -f pv.yml

@@ Create PVC.

[root@k8s-control01 ~]# vim pvc.yml
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: nfs-pvc
spec:
  accessModes:
  - ReadWriteMany
  resources:
    requests:
      storage: 5Gi

@@ Apply:
[root@k8s-control01 ~]# kubectl apply -f pvc.yml

@@ Verify:
[root@k8s-control01 ~]# kubectl get pv,pvc

@@ Output:

PV      Bound

PVC     Bound


###################################################
Problem with Static Provisioning

Imagine: 100 Developers,500 Applications and 1000 PVCs.
Do you want to create 1000 PVs manually? No.

Need automation.

Dynamic Provisioning

Storage should be created automatically.

@@ Architecture:

PVC
 |
StorageClass
 |
Provisioner
 |
NFS

@@ What is a StorageClass?

Think of StorageClass as Storage Template

Example: storageClassName: nfs-client

@@ What is a Provisioner?

Provisioner automatically creates storage.

Example: NFS Subdir External Provisioner

Whenever PVC is created: Create New Directory

Create PV Bind PVC Automatically.


###############################################
### Install NFS Subdir External Provisioner ###

@@ Create namespace:

[root@k8s-control01 ~]# kubectl create ns nfs-provisioner

@@ Add Helm repo:

[root@k8s-control01 ~]# curl -fsSL -o get_helm.sh https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-4
[root@k8s-control01 ~]# chmod 700 get_helm.sh
[root@k8s-control01 ~]# ./get_helm.sh
[root@k8s-control01 ~]# helm repo add nfs-subdir-external-provisioner https://kubernetes-sigs.github.io/nfs-subdir-external-provisioner
[root@k8s-control01 ~]# helm repo update

@@ Install:
[root@k8s-control01 ~]# helm install nfs-storage nfs-subdir-external-provisioner/nfs-subdir-external-provisioner -n nfs-provisioner --set nfs.server=10.2.4.70 --set nfs.path=/nfs-share/k8s

@@ Verify:
[root@k8s-control01 ~]# kubectl get pods -n nfs-provisioner

@@ Expected:
Running

