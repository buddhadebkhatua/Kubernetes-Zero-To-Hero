########################################
####### Create First StorageClass ############

apiVersion: storage.k8s.io/v1
kind: StorageClass

metadata:
  name: fast-storage

provisioner: kubernetes.io/no-provisioner

volumeBindingMode: WaitForFirstConsumer

@@ Apply:
[root@k8s-control01 ~]#  kubectl apply -f storageclass.yaml

@@ Verify:
[root@k8s-control01 ~]#  kubectl get sc


Important Note: In Minikube/Kubeadm Labs StorageClass may not dynamically create storage without a CSI Driver.
This is normal.


#######################################
###### Create PVC Using StorageClass  ###############

PVC:

apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: app-pvc
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: fast-storage
  resources:
    requests:
      storage: 1Gi

@@ Apply:
[root@k8s-control01 ~]# kubectl apply -f pvc.yaml

@@ Check:
[root@k8s-control01 ~]# kubectl get pvc
[root@k8s-control01 ~]# kubectl get pv

@@ Result:
PV Created Automatically

when dynamic provisioning exists.


