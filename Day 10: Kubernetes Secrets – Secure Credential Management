################ Mount Secret as File ##############
Many applications require Certificate Files, Private Keys, SSH Keys instead of environment variables.

@@ Create Secret
[root@k8s-control01 ~]# kubectl create secret generic ssl-secret --from-file=tls.crt --from-file=tls.key

@@ Mount:
volumeMounts:
- name: secret-volume
  mountPath: /etc/ssl/private
volumes:
- name: secret-volume
  secret:
    secretName: ssl-secret

@@ Verify:
[root@k8s-control01 ~]# kubectl exec -it POD_NAME -- ls /etc/ssl/private

@@ Output:
tls.crt
tls.key

######################################
########### Secret Types ###########
List Secret Types:

1. Opaque Secret (Default type.)
@@ Example:
[root@k8s-control01 ~]#  kubectl create secret generic
@@ Used for:
Passwords
Tokens
API Keys

2. TLS Secret
Used for HTTPS.
@@ Create:
[root@k8s-control01 ~]#  kubectl create secret tls website-tls --cert=tls.crt --key=tls.key
@@ Used by:
Ingress
NGINX
Web Applications

3. Docker Registry Secret
Required for private container images.
@@ Example:
[root@k8s-control01 ~]#  kubectl create secret docker-registry regcred --docker-server=registry.company.com --docker-username=admin --docker-password=password

@@ Use:
imagePullSecrets:
- name: regcred

