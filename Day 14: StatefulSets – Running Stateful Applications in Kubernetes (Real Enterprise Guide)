###################################
####### Headless Service ##########

StatefulSets require a Headless Service.

@@ Unlike ClusterIP:
clusterIP: None

[root@k8s-control01 ~]# vim headless-service.yml
apiVersion: v1
kind: Service
metadata:
  name: mysql
spec:
  clusterIP: None
  selector:
    app: mysql
  ports:
  - port: 3306

@@ Apply:
[root@k8s-control01 ~]# kubectl apply -f headless-service.yml

@@ Verify
[root@k8s-control01 ~]# kubectl get svc

@@ Output
mysql
ClusterIP None


@@ Why Headless Service?
=> Each Pod gets DNS.

@@ Example:
mysql-0.mysql.default.svc.cluster.local
mysql-1.mysql.default.svc.cluster.local
mysql-2.mysql.default.svc.cluster.local

Applications can communicate directly.

###################################################
####### Create Your First StatefulSet ##########

[root@k8s-control01 ~]# vim statefulset.yml
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: nginx
spec:
  serviceName: nginx
  replicas: 3
  selector:
    matchLabels:
      app: nginx

  template:
    metadata:
      labels:
        app: nginx

    spec:
      containers:
        - name: nginx
          image: nginx
          volumeMounts:
            - name: data
              mountPath: /usr/share/nginx/html

  volumeClaimTemplates:
  - metadata:
     name: data
    spec:
      accessModes:
      - ReadWriteOnce
      storageClassName: nfs-client
      resources:
        requests:
          storage: 1Gi

@@ Deploy:
[root@k8s-control01 ~]# kubectl apply -f statefulset.yml

@@ Verify:
[root@k8s-control01 ~]# kubectl get statefulset
[root@k8s-control01 ~]# kubectl get pods
[root@k8s-control01 ~]# kubectl get pvc
[root@k8s-control01 ~]# kubectl get pv


