########## emptyDir Volume ##############
@@ Create:
[root@k8s-control01 ~]# vim emptydir.yml
apiVersion: v1
kind: Pod
metadata:
  name: emptydir-demo
spec:
  containers:
  - name: app
    image: busybox
    command:
      - sh
      - -c
      - sleep 3600
    volumeMounts:
    - name: shared-data
      mountPath: /data
  volumes:
  - name: shared-data
    emptyDir: {}

@@ Apply:
[root@k8s-control01 ~]# kubectl apply -f emptydir.yml

@@ Login:
[root@k8s-control01 ~]# kubectl exec -it emptydir-demo -- sh

@@ Create file:
[root@k8s-control01 ~]# echo "hello" > /data/test.txt

@@ Verify:
[root@k8s-control01 ~]# cat /data/test.txt

@@ Restart Container:
[root@k8s-control01 ~]# kubectl delete pod emptydir-demo

Recreate.
Check file.

@@ Result:
Data Lost

@@ Because:
Pod Deleted
emptyDir Deleted

Difference between Container Storage and emptyDir?

Container Storage: Deleted when container restarts
emptyDir: Survives container restart & Lost when Pod deleted

