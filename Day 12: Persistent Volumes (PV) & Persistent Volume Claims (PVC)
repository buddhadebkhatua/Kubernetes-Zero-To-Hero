#########################################
###### Real MySQL Project  ########

@@ Deploy PV:

[root@k8s-control01 ~]# vim pv-mysql.yml
apiVersion: v1
kind: PersistentVolume
metadata:
  name: mysql-disk-01
  labels:
    usage: mysql-fast-storage
spec:
  capacity:
    storage: 1Gi
  accessModes:
    - ReadWriteOnce
  hostPath:
    path: "/data/mysql"

@@ Deploy PVC:

[root@k8s-control01 ~]# vim pvc-mysql.yml
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: mysql-dedicated-pvc
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 1Gi
  selector:
    matchLabels:
      usage: mysql-fast-storage


@@ Deploy MySQL:

[root@k8s-control01 ~]# vim pod-mysql.yml
apiVersion: v1
kind: Pod
metadata:
  name: mysql-pod
  labels:
    app: mysql-db
spec:
  nodeSelector:
    kubernetes.io/hostname: k8s-control01
  containers:
    - name: mysql
      image: mysql:8.0
      env:
        - name: MYSQL_ROOT_PASSWORD
          value: "mysql@123"
        - name: MYSQL_DATABASE
          value: "app_database"
      ports:
        - containerPort: 3306
          name: mysql-port
      volumeMounts:
        - name: mysql-persistent-storage
          mountPath: /var/lib/mysql

  volumes:
    - name: mysql-persistent-storage
      persistentVolumeClaim:
        claimName: mysql-dedicated-pvc


@@ Architecture:

MySQL
  |
mysql-pvc
  |
PV
  |
Storage

