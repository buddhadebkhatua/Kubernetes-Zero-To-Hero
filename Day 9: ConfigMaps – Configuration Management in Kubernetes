######## Using ConfigMap as Files ########
Many enterprise applications expect configuration files.

@@ Example:
application.properties
nginx.conf
httpd.conf

@@ Create ConfigMap
[root@k8s-control01 ~]# vim nginx-cu-configmap.yml
apiVersion: v1
kind: ConfigMap
metadata:
  name: nginx-config
data:
  custom.conf: |
    server {
      listen 80;
      location / {
        return 200 'Hello Kubernetes';
      }
    }


@@ Mount into Pod:
[root@k8s-control01 ~]# vim nginx-cu-deployment.yml
apiVersion: v1
kind: Pod
metadata:
  name: nginx-custom-pod
  labels:
    app: nginx-custom
spec:
  containers:
    - name: nginx
      image: nginx:alpine
      ports:
        - containerPort: 80
      volumeMounts:
        # Mount the volume inside the container's Nginx config directory
        - name: config-volume
          mountPath: /etc/nginx/conf.d/
  volumes:
    # Define the volume pulling from your ConfigMap
    - name: config-volume
      configMap:
        name: nginx-config

@@ Verify:
[root@k8s-control01 ~]# kubectl exec -it POD_NAME -- ls /etc/nginx/conf.d

@@ Expected:
custom.conf

@@ Why doesn't ConfigMap update automatically inside environment variables?
=> Environment variables are loaded only at container startup.


