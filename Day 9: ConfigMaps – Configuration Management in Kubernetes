##### Real-World Scenario #####
Imagine, you have Payment Application

@@ Dev Environment:
DB_HOST=dev-db.company.local

@@ QA Environment:
DB_HOST=qa-db.company.local

@@ Production:
DB_HOST=prod-db.company.local

Without ConfigMaps Build New Image Deploy Again. Every configuration change requires rebuilding the application. Not practical.

@@ What is a ConfigMap?
=> A ConfigMap stores non-sensitive configuration data separately from application code.

@@ Example:
Application
      ⬇︎
Configuration
      ⬇︎
ConfigMap

@@ Benefits:
Separation of Code and Configuration
Easy Updates
Environment-Specific Settings

#########################################
######## Create First ConfigMap #######
@@ Create:
[root@k8s-control01 ~]# vim configmap.yml
apiVersion: v1
kind: ConfigMap
metadata:
  name: app-config
data:
  APP_ENV: "development"
  LOG_LEVEL: "debug"

@@ Apply:
[root@k8s-control01 ~]# kubectl apply -f configmap.yml

@@ Verify:
[root@k8s-control01 ~]# kubectl get configmap

@@ Output:
app-config

@@ Inspect:
[root@k8s-control01 ~]# kubectl describe configmap app-config


####################################################
##### Using ConfigMap as Environment Variables #####
@@ Create Deployment:
[root@k8s-control01 ~]# vim deployment.yml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: config-demo
spec:
  replicas: 1
  selector:
    matchLabels:
      app: config-demo
  template:
    metadata:
      labels:
        app: config-demo
    spec:
      containers:
      - name: app
        image: nginx
        env:
        - name: APP_ENV
          valueFrom:
            configMapKeyRef:
              name: app-config
              key: APP_ENV
        - name: LOG_LEVEL
          valueFrom:
            configMapKeyRef:
              name: app-config
              key: LOG_LEVEL

@@ Deploy:
[root@k8s-control01 ~]# kubectl apply -f deployment.yml

@@ Verify:
[root@k8s-control01 ~]# kubectl exec -it POD_NAME -- env | grep APP_ENV

@@ Output:
APP_ENV=development

####################################################
########## Import Entire ConfigMap ################
Instead of individual variables:
[root@k8s-control01 ~]# vim deployment.yml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: config-demo
spec:
  replicas: 1
  selector:
    matchLabels:
      app: config-demo
  template:
    metadata:
      labels:
        app: config-demo
    spec:
      containers:
      - name: app
        image: nginx
        envFrom:
          - configMapRef:
              name: app-config

All keys become environment variables.

