#########################################
########## NodePort Service ############
@@ How do users access applications from outside?
= > Using NodePort.

@@ Architecture
 Internet
    ⬇︎
NodeIP:30080
    ⬇︎
Service
    ⬇︎
  Pods

@@ Create NodePort
[root@k8s-control01 ~]# vim nodeport.yml
apiVersion: v1
kind: Service
metadata:
  name: nginx-nodeport
spec:
  type: NodePort
  selector:
    app: nginx
  ports:
  - port: 80
    targetPort: 80
    nodePort: 30080

@@ Apply:
[root@k8s-control01 ~]# kubectl apply -f nodeport.yml

@@ Verify:
[root@k8s-control01 ~]# kubectl get svc

@@ Access
http://NODE-IP:30080

